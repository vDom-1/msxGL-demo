                                    407 ;------------------------------------------------------------------------------
                                    408 ; Delay boot using STKE hook
                                    409 ;------------------------------------------------------------------------------
                                    410 .macro DELAY_BOOT
                                    411 	.if ROM_DELAY
                                    412 	; Setup the hook H.STKE to run the ROM with disk support
                                    413 	crt0_bdos_install::
                                    414 		ld		a, c					; Get the ROM slot number
                                    415 		ld		hl, #crt0_bdos_hook
                                    416 		ld		de, #H_STKE
                                    417 		ld		bc, #4
                                    418 		ldir							; Copy the routine to execute the ROM to the hook
                                    419 		ld		(H_STKE+1), a			; Put the ROM slot number to the hook
                                    420 		ret								; Back to slots scanning
                                    421 
                                    422 	; Routine to execute the ROM
                                    423 	crt0_bdos_hook:
                                    424 		rst		0x30					; Inter-slot call
                                    425 		.db		1						; This byte will be replaced by the slot number of ROM
                                    426 		.dw		crt0_bdos_end			; Address to execute the ROM
                                    427 
                                    428 	; Remove the hook and resume the ROM boot sequence
                                    429 	crt0_bdos_end:
                                    430 		ld		a, #0xC9				; 'ret' instruction
                                    431 		ld		(H_STKE), a
                                    432 	.endif
                                    433 .endm
