                                    139 ;------------------------------------------------------------------------------
                                    140 ; Initialize globals
                                    141 ;------------------------------------------------------------------------------
                                    142 .macro INIT_GLOBALS
                                    143 
                                    144 	crt0_init_globals:
                                    145 		ld		bc, #l__INITIALIZER
                                    146 		ld		a, b
                                    147 		or		a, c
                                    148 		jp		z, crt0_skip_globals
                                    149 		ld		de, #s__INITIALIZED
                                    150 		ld		hl, #s__INITIALIZER
                                    151 		ldir
                                    152 	crt0_skip_globals:
                                    153 
                                    154 .endm
                                    155 
                                    156 ;------------------------------------------------------------------------------
                                    157 ; Set page #2 at the same slot than the page #1 (for 32K ROM)
                                    158 ;------------------------------------------------------------------------------
                                    159 .macro INIT_P1_TO_P2
                                    160 
                                    161 	crt0_p1_to_p2::
                                    162 		in		a, (PPI_A)				; A=[P3|P2|P1|P0] Get primary slots info
                                    163 		rrca
                                    164 		rrca							; A=[P0|P3|P2|P1]
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 9
Hexadecimal [32-Bits]



                                    165 		and		a, #0b00000011			; A=[00|00|00|P1] Save Page 1 primary slot
                                    166 		ld		c, a					; C=[00|00|00|P1]
                                    167 		ld		hl, #EXPTBL				; HL=&EXPTBL
                                    168 		add		a, l
                                    169 		ld		l, a
                                    170 		ld		a, (hl)					; A=EXPTBL[P1]    See if the slot is expanded or not
                                    171 		and		a, #0x80				; A=[X|000|00|00] Keep only expansion flag
                                    172 		or		a, c					; A=[X|000|00|P1] Set MSB if so
                                    173 		ld		c, a					; C=[X|000|00|P1] Save it to [C]
                                    174 		inc		l						;                 Point to primary slot's SLTTBL entry
                                    175 		inc		l
                                    176 		inc		l
                                    177 		inc		l
                                    178 		ld		a, (hl)					; A=SLTTBL[P1]    Get what is currently output to expansion slot register
                                    179 		and		a, #0b00001100			; A=[00|00|S1|00]
                                    180 		or		c						; A=[X|000|S1|P1] Finally form slot address
                                    181 		ld		h, #0x80				; H=Page 2
                                    182 		call	ENASLT					;                 Enable page 1's slot in page 2
                                    183 .endm
                                    184 
                                    185 ;------------------------------------------------------------------------------
                                    186 ; Set pages #0 and #2 at the same slot than the page #1 (for 48K ROM)
                                    187 ;------------------------------------------------------------------------------
                                    188 .macro INIT_P1_TO_P02
                                    189 
                                    190 	; Backup Page 0 (Main-ROM) information
                                    191 	BACKUP_ROMINFO
                                    192 
                                    193 	; Call event before BIOS release
                                    194 	ON_BIOS_RELEASE
                                    195 
                                    196 	crt0_p1_to_p02::
                                    197 		; Set all pages primary slot equal to page #1 one
                                    198 		in		a, (PPI_A)				; A=[P3|P2|P1|P0] Get primary slots info
                                    199 		ld		d, a					; D=[P3|P2|P1|P0] Backup full slots info
                                    200 		and		a, #0b00001100			; A=[00|00|P1|00] Mask all pages slots but P1 
                                    201 		ld		c, a					; C=[00|00|P1|00] Backup P1
                                    202 		rrca							;                 A>>1
                                    203 		rrca							; A=[00|00|00|P1] A>>1
                                    204 		or		a, c					; A=[00|00|P1|P1]
                                    205 		ld		c, a					; C=[00|00|P1|P1] Backup 
                                    206 		add		a, a					;                 A<<1
                                    207 		add		a, a					; A=[00|P1|P1|00] A<<1
                                    208 		add		a, a					;                 A<<1
                                    209 		add		a, a					; A=[P1|P1|00|00] A<<1
                                    210 		or		a, c					; A=[P1|P1|P1|P1] Merge
                                    211 		out		(PPI_A), a				;                 Set primary slots info
                                    212 		ld		e, a					; E=[P1|P1|P1|P1] Backup new slots
                                    213 
                                    214 		; Set page #0 and 2 at the same secondary slot than page #1 one
                                    215 		ld		a, (SLTSL)				; A=[~3|~2|~1|~0] Read secondary slots register of selected primary slot
                                    216 		cpl								; A=[S3|S2|S1|S0] Reverses the bits
                                    217 		ld		b, a					; B=[S3|S2|S1|S0] Backup secondary slot
                                    218 		and		a, #0b00001100			; A=[00|00|S1|00] Mask all pages secondary slots but P1 
                                    219 		ld		c, a					; C=[00|00|S1|00] Backup
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                           Page 10
Hexadecimal [32-Bits]



                                    220 		rrca							;                 A>>1
                                    221 		rrca							; A=[00|00|00|S1] A>>1
                                    222 		or		a, c					; A=[00|00|S1|S1] Merge
                                    223 		ld		c, a					; C=[00|00|S1|S1] Backup
                                    224 		add		a, a					;                 A<<1
                                    225 		add		a, a					; A=[00|S1|S1|00] A<<1
                                    226 		or		a, c					; A=[00|S1|S1|S1] Merge
                                    227 		ld		c, a					; C=[00|S1|S1|S1] Backup
                                    228 		ld		a, b					; A=[S3|S2|S1|S0] Restore primary slots info 
                                    229 		and		a, #0b11000000			; A=[S3|00|00|00] Mask all pages slots but P0 
                                    230 		or		a, c					; A=[S3|S1|S1|S0] Merge original P0 and P1 in all other page
                                    231 		ld		(SLTSL), a				;                 Set secondary slot info
                                    232 
                                    233 		; Restore initial Page 3 slot
                                    234 		ld		a, d					; A=[P3|P2|P1|P0] Restore initiale primary slots
                                    235 		and		a, #0b11000000			; A=[P3|00|00|00] Keep page #3 primary slot
                                    236 		ld		c, a					; C=[P3|00|00|00] Backup
                                    237 		ld		a, e					; A=[P1|P1|P1|P1] Restore new primary slots
                                    238 		and		a, #0b00111111			; A=[00|P1|P1|P1] Keep all pages but page #3
                                    239 		or		a, c					; A=[P3|P1|P1|P1] Merge
                                    240 		out		(PPI_A), a				;                 Set primary slots info
                                    241 .endm
