                         00000003    80 ROM_KONAMI		= 3		;  Konami without SCC mapper
                         00000004    81 ROM_KONAMI_SCC	= 4		;  Konami with SCC mapper
                         00000005    82 ROM_NEO8		= 5		;  NEO-8 mapper
                         00000006    83 ROM_YAMANOOTO	= 6		;  Yamanooto mapper
