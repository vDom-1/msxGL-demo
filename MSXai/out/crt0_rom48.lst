                                    442 		ld		a, (MSXVER)
                                    443 		cp		#CHECK_MSX
                                    444 		jp		nc, crt0_check_msx_end ; Version must be equal or higher
                                    445 
                                    446 		ld		a, #40
                                    447 		ld		(LINL40), a			; Set number of columns
                                    448 		call	INITXT				; Switch to Screen 0 (text mode)
                                    449 
                                    450 		ld		hl, #crt0_check_msx_message
                                    451 		call	crt0_check_msx_print ; Display error message
                                    452 
                                    453 	crt0_check_msx_loop:
                                    454 		call	CHGET				; Waiting for user to press a key
                                    455 		cp		#67 				; Character 'C'
                                    456 		jp		z, crt0_check_msx_end
                                    457 		cp		#99 				; Character 'c'
                                    458 		jp		z, crt0_check_msx_end
                                    459 		jr		crt0_check_msx_loop
                                    460 
                                    461 	crt0_check_msx_print:
                                    462 		ld		a, (hl)
                                    463 		or		a
                                    464 		ret		z
                                    465 		call	CHPUT
                                    466 		inc		hl
                                    467 		jr		crt0_check_msx_print
                                    468 
                                    469 	crt0_check_msx_message:
                                    470 		.ascii	"Error: A "
                                    471 		.ifeq CHECK_MSX-MSX2
                                    472 		.ascii	"MSX2"
                                    473 		.endif
                                    474 		.ifeq CHECK_MSX-MSX2P
                                    475 		.ascii	"MSX2+"
                                    476 		.endif
                                    477 		.ifeq CHECK_MSX-MSXTR
                                    478 		.ascii	"MSX turbo R"
                                    479 		.endif
                                    480 		.ascii	" is required!\n\n\n\rPress [C] to continue anyway.\0"
                                    481 
                                    482 	crt0_check_msx_end:
                                    483 	.endif
                                    484 .endm
