                                    390 ;------------------------------------------------------------------------------
                                    391 ; Check for skip key press
                                    392 ;------------------------------------------------------------------------------
                                    393 .macro SKIP_BOOT
                                    394 	.if ROM_SKIP
                                    395 	; Check for 'ESC' key press
                                    396 	ctr0_check_rom_skip:
                                    397 		in		a, (PPI_C)
                                    398 		and		#0xF0					; only change bits 0-3
                                    399 		or		#7						; check row number 7
                                    400 		out		(PPI_C), a
                                    401 		in		a, (PPI_B)				; read row into A
                                    402 		and		#ROM_SKIP_KEY
                                    403 		ret		z
                                    404 	.endif
                                    405 .endm
