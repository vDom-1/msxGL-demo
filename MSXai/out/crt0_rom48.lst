                                    243 ;------------------------------------------------------------------------------
                                    244 ; Set page #0 at the same slot than the page #3 (replace Main-ROM by RAM)
                                    245 ; /!\ Need 64 KB of RAM
                                    246 ;------------------------------------------------------------------------------
                                    247 .macro INIT_P3_TO_P0
                                    248 
                                    249 	; Backup Page 0 (Main-ROM) information
                                    250 	BACKUP_ROMINFO
                                    251 
                                    252 	; Call event before BIOS release
                                    253 	ON_BIOS_RELEASE
                                    254 
                                    255 	crt0_p3_to_p0::
                                    256 
                                    257 		; Code by retrocanada76
                                    258 		; https://msx.org/forum/msx-talk/development/msxgl-%E2%80%93-a-new-c-game-library-for-msx?page=28
                                    259 
                                    260 		; D = current SLOT config (P3|P2|P1|P0)
                                    261 		; E = current SLTSL reg (P3)
                                    262 		in		a, (PPI_A)				; get current SLOTs
                                    263 		ld		e, a					; save for later (E)
                                    264 		ld		a, (SLTSL)				
                                    265 		cpl								; get current SSLOTs (P3)
                                    266 		ld		d,a						; save for later (D)
                                    267 
                                    268 		; Set pages #0 primary slot equal to page #3 one
                                    269 		in		a, (PPI_A)				; A=[P3|P2|P1|P0] Get primary slots info 
                                    270 		and		a, #0b11111100			; A=[P3|P2|P1|00] Mask P0 slot 
                                    271 		ld		b, a					; B=[P3|P2|P1|00] Backup
                                    272 		and		a, #0b11000000			; A=[P3|00|00|00] Mask all pages slots but P3 
                                    273 		rlca							;                 A<<1
                                    274 		rlca							; A=[00|00|00|P3] A<<1
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                           Page 11
Hexadecimal [32-Bits]



                                    275 		or		a, b					; A=[P3|P2|P1|P3] Merge
                                    276 		out		(PPI_A), a				;                 Set primary slots info
                                    277 
                                    278 		; Set page #0 seconday slot equal to page #3 one
                                    279 		ld		a, (SLTSL)				; A=[~3|~2|~1|~0] Read secondary slots register of selected primary slot
                                    280 		cpl								; A=[S3|S2|S1|S0] Reverses the bits
                                    281 		and		a, #0b11111100			; A=[S3|S2|S1|00] Mask S0 slot 
                                    282 		ld		b, a					; B=[S3|S2|S1|00] Backup
                                    283 		and		a, #0b11000000			; A=[S3|00|00|00] Mask all pages slots but S3 
                                    284 		rlca							;                 A<<1
                                    285 		rlca							; A=[00|00|00|S3] A<<1
                                    286 		or		a, b					; A=[S3|S2|S1|S3] Merge
                                    287 		ld		(SLTSL), a				;                 Set secondary slot info
                                    288 
                                    289 		ld		a,(0)					; read from P0
                                    290 		ld		h,a						; save for comparison
                                    291 		cpl								; make it inverse
                                    292 		ld		(0),a					; write back to P0
                                    293 		ld		a,(0)					; read again
                                    294 		cp		h						; compare against original
                                    295 		jr		nz, #ram_found			; not the same ? RAM found here
                                    296 
                                    297 		; RAM deep search
                                    298 		; this routine search for RAM on P0. It searches each subslot as the RAM might be fragmented (Victor HC-80 or Sony HB-F900 rev1)
                                    299 		; it could be also MSX1s with RAM expansion cards
                                    300 		; into several 16K chunks.
                                    301 		; B = probing SSLOT (3 - 0)
                                    302 		; C = probing SLOT (3 - 0) (P3|P0)
                                    303 		; L = saved SLTSL reg for probing SLOT
                                    304 
                                    305 		ld		a,#0b11000011			; set probing SLOTs P0 and P3 to SLOT 3
                                    306 
                                    307 	slot_loop:
                                    308 		ld		c,a						; save probing P0 and P3
                                    309 
                                    310 		in		a, (PPI_A)				; read current SLOTs
                                    311 		and		#0b00111100				; mask out P0 and P3
                                    312 		or		c						; set P0 and P3 to current probing SLOTs
                                    313 		out		(PPI_A),a				
                                    314 
                                    315 		ld		b, #4					; probe for 4 SSLOTs	
                                    316 	sslot_loop:
                                    317 		ld		a, (SLTSL)				; read SSLOT reg
                                    318 		cpl								; get current SSLOTs for probing SLOT
                                    319 		ld		l, a					; save for later (L)
                                    320 		and		#0b11111100				; mask out P0
                                    321 		dec		b						; dec probing SSLOT (started on #4)
                                    322 		or		b						; set probing P0 SSLOT
                                    323 		ld		(SLTSL), a				; write SSLOT reg
                                    324 
                                    325 		ld		a,(0)					; read from P0
                                    326 		ld		h,a						; save for comparison
                                    327 		cpl								; make it inverse
                                    328 		ld		(0),a					; write back to P0
                                    329 		ld		a,(0)					; read again
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                           Page 12
Hexadecimal [32-Bits]



                                    330 		cp		h						; compare against original
                                    331 		jr		nz, #ram_found			; not the same ? RAM found here
                                    332 
                                    333 		xor		a						; this SSLOT is not RAM
                                    334 		or 		b 						; check SSLOT counter
                                    335 		jr		nz, #sslot_loop			; repeat if still SSLOT left
                                    336 
                                    337 		ld		a,l						; no more SSLOTs for this SLOT
                                    338 		ld 		(SLTSL), a				; restore saved SSLOT for probing SLOT (L)
                                    339 
                                    340 		ld		a, e
                                    341 		out		(PPI_A), a 				; restore saved SLOT (E)
                                    342 		ld		a, d
                                    343 		ld		(SLTSL), a 				; restore saved SSLOT (D)
                                    344 
                                    345 		xor		a
                                    346 		or		c						; has ended ?
                                    347 		jr		z, #ram_not_found
                                    348 		sub		#0b01000001				; dec SLOTS P0 and P3
                                    349 		jr		#slot_loop				; repeat next slot
                                    350 
                                    351 	ram_found:
                                    352 		cpl								; ram has been found
                                    353 		ld		(0),a 					; restore original RAM content
                                    354 
                                    355 		ld		a,e						; now we found P0 ram lets 
                                    356 		and		#0b11000000				; extract P3 original SLOT
                                    357 		ld		e,a						; keep only original P3
                                    358 
                                    359 		in		a,(PPI_A)				; read actual SLOT config
                                    360 		and		#0b00111111				; mask out P3 from current config
                                    361 		or		e
                                    362 		out		(PPI_A),a				; set back original P3 SLOT
                                    363 
                                    364 		ld		a, d					; do the same now with SSLOT
                                    365 		and		#0b11000000				; extract P3 from original SSLOT
                                    366 		ld		d,a
                                    367 		ld		a,(SLTSL)				; read actual SSLOT
                                    368 		cpl
                                    369 		and		#0b00111111				; mask out P3
                                    370 		or		d						; set back original P3 SSLOT
                                    371 		ld		(SLTSL), a 				; restore orig sslot
                                    372 
                                    373 	ram_not_found:
                                    374 
                                    375 .endm
                                    376 
